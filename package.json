{
  "name": "caas-lite",
  "version": "0.1.0",
  "description": "Event-driven Compliance-as-a-Service (CaaS) Lite platform",
  "main": "dist/index.js",
 "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
