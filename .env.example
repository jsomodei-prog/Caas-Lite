# .env.example
# Copy this file to .env and fill in all values before starting the server.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/caas_evidence.db

# ── HMAC / Signing ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
PAYOUT_HMAC_SECRET=change_me_to_a_64_byte_random_hex_string_for_production

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all (dev only).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Set to "true" to treat requests with missing X-CaaS-Tier as PAY_AS_YOU_GO.
RATE_LIMIT_ALLOW_UNKNOWN_TIER=true
# Optional per-tier overrides (integers):
# TIER_OVERRIDE_ENTERPRISE_RPM=3000
# TIER_OVERRIDE_ENTERPRISE_BURST=600
# TIER_OVERRIDE_GROWTH_RPM=500

# ── Performance Monitoring ────────────────────────────────────────────────────
# Queries slower than this threshold (ms) are written to slow_query_log.
SLOW_QUERY_THRESHOLD_MS=100

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_TEMP_DIR=tmp/backups
# Local filesystem replica (required for failover):
BACKUP_FS_DIR=data/replicas
BACKUP_FS_RETENTION=7
# Cron schedule for automatic backups (default: 02:00 UTC daily):
BACKUP_CRON_SCHEDULE=0 2 * * *

# ── AWS S3 Backup (optional) ──────────────────────────────────────────────────
# Leave blank to disable S3 backup.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BACKUP_S3_BUCKET=
# BACKUP_S3_PREFIX=backups/
# BACKUP_S3_RETENTION_DAYS=30
# BACKUP_S3_ENDPOINT=          # For MinIO / Cloudflare R2

# ── FX Service ────────────────────────────────────────────────────────────────
FX_RATE_TTL_MINUTES=15
FX_SPREAD_FRACTION=0.005
# Primary provider (Open Exchange Rates):
# OXR_APP_ID=
# Failover provider (Fixer.io):
# FIXER_API_KEY=
# Last-resort provider (ExchangeRate-API):
# EXCHANGERATE_API_KEY=

# ── MoMo Disbursement API ─────────────────────────────────────────────────────
MOMO_API_BASE=https://sandbox.momodeveloper.mtn.com
MOMO_TARGET_ENV=sandbox
# MOMO_SUBSCRIPTION_KEY=
# MOMO_API_USER=
# MOMO_API_KEY_SECRET=

# ── Card Gateway (Stripe) ─────────────────────────────────────────────────────
CARD_GATEWAY_BASE=https://api.stripe.com
# CARD_GATEWAY_SECRET=sk_test_...

# ── Anomaly Alerting ──────────────────────────────────────────────────────────
# ANOMALY_ALERT_WEBHOOK=https://hooks.slack.com/services/...
# ANOMALY_EMAIL_API_URL=https://api.sendgrid.com/v3/mail/send
# ANOMALY_EMAIL_API_KEY=
# ANOMALY_EMAIL_TO=alerts@yourcompany.com
# ANOMALY_EMAIL_FROM=caas-alerts@yourcompany.com

# ── Regulatory Reporting ──────────────────────────────────────────────────────
# REGULATORY_REPORT_WEBHOOK=https://your-compliance-system/webhook
