# .env.example
# Copy to `.env` and fill in real values before deploying.
# Never commit `.env` itself — it should be in .gitignore.

# ─── Database ─────────────────────────────────────────────────────────────────

# SQLite DB file location inside the container. The data:/data volume
# in docker-compose.yml persists this across restarts.
DB_PATH=/data/caas_evidence.db

# ─── HTTP Server ──────────────────────────────────────────────────────────────

PORT=3000

# ─── JWT (Auth) ───────────────────────────────────────────────────────────────

# Secret used for signing access tokens. Required.
# Generate: openssl rand -hex 32
JWT_SECRET=

# ─── Payout HMAC (Tax Receipts) ───────────────────────────────────────────────

# Used to sign PDF tax receipts. Required for production.
# Generate: openssl rand -hex 32
PAYOUT_HMAC_SECRET=

# ─── Badge HMAC Secret (Trust Badges) ─────────────────────────────────────────
#
# The badge signing secret supports rolling rotation via two variables.
# Read docs/SECRET_ROTATION.md before changing these in production.
#
# Quick reference:
#   BADGE_HMAC_SECRET_CURRENT   — signs new badges; verified first
#   BADGE_HMAC_SECRET_PREVIOUS  — accepted for verification only during cutover
#
# On boot, the server detects whether _CURRENT has changed since the last
# boot. If yes, every badge in trust_badge_registry is automatically
# re-signed with the new secret. Audit entries are written to
# commercial_audit_log with action='secret_rotation'.

# Generate: openssl rand -hex 32
BADGE_HMAC_SECRET_CURRENT=

# Leave empty unless you're mid-rotation. When set, signatures minted
# under this older secret will still validate (with X-Badge-Signature-Stale
# header) so embedders have time to refresh their pinned signatures.
# Remove this line after rotation cutover is complete.
BADGE_HMAC_SECRET_PREVIOUS=

# Legacy single-secret env var. Used as a fallback only when neither
# _CURRENT nor _PREVIOUS is set. Pre-rotation deployments can keep
# using just this; new deployments should use _CURRENT.
# BADGE_HMAC_SECRET=

# ─── File Storage ─────────────────────────────────────────────────────────────

# Where PDF tax receipts are written. Mounted as a Docker volume.
RECEIPTS_DIR=/app/data/receipts

# Platform display name on generated PDFs and emails.
PLATFORM_NAME=CaaS-Lite Platform

# ─── Operational Flags ────────────────────────────────────────────────────────

# Set to "false" on additional app instances when running multiple
# containers behind a load balancer. Only one instance should run the
# recompute scheduler timer to avoid duplicate audit log entries.
# Default (unset) is enabled.
# RECOMPUTE_SCHEDULER_ENABLED=true

# ─── CORS Allow-list ──────────────────────────────────────────────────────────
#
# Comma-separated list of origins (full, with protocol) allowed to make
# cross-origin requests. Required for any browser dashboard you build.
# Leave empty to deny all cross-origin requests (badge endpoint is
# exempt and remains permissive by design).
#
# Example:
#   CORS_ALLOWED_ORIGINS=https://dashboard.caas.example.com,https://staging.caas.example.com
CORS_ALLOWED_ORIGINS=

# ─── NODE_ENV ─────────────────────────────────────────────────────────────────
#
# When set to "production", enables HSTS (forces HTTPS via Strict-Transport-
# Security header). When set to "test", disables rate limits so tests don't
# get spurious 429s from parallelism.
NODE_ENV=production
