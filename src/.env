# caas-lite environment — Phase 4
# ─────────────────────────────────────────────────────────────────────────────

# Webhook HMAC secret (required)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=dev-secret-change-me
HEADER_API_KEY=dev-api-key-change-me
ALERT_FORWARD_URL=https://webhook.site/6cdf12f2-f188-45dc-9b7f-a54f637585af

# API key — protects GET /api/evidence and GET /dashboard
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
HEADER_API_KEY=dev-api-key-change-me

# Alert forwarding — POST payload to this URL on every policy failure
# Use https://webhook.site to get a free test URL, or leave blank to disable
ALERT_FORWARD_URL=https://webhook.site/your-unique-id-here

# Optional overrides
# PORT=3000
# POLICY_TEMPLATE_PATH=./policies
